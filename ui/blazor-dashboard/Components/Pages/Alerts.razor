@page "/alerts"
@rendermode InteractiveServer
@using AetherStream.Dashboard.Models
@using AetherStream.Dashboard.Services
@inject DashboardState DashboardState
@inject DashboardDisplay Display
@implements IDisposable

<PageTitle>Alerts - AetherStream</PageTitle>

<RadzenText TextStyle="TextStyle.H4" TagName="TagName.H2">Alerts</RadzenText>
<ConnectionStatus />

@if (_alerts.Count == 0)
{
    <RadzenAlert AlertStyle="AlertStyle.Success" Shade="Shade.Lighter">
        No alerts — anomaly stream is quiet.
    </RadzenAlert>
}
else
{
    @foreach (var alert in _alerts)
    {
        <RadzenCard class="rz-mb-2">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem" Wrap="FlexWrap.Wrap">
                <RadzenBadge BadgeStyle="@AlertBadgeStyle.ForSeverity(alert.Severity)" Text="@alert.Severity" />
                <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@alert.Type" />
                <RadzenText TextStyle="TextStyle.Body1">@alert.Message</RadzenText>
                <RadzenText TextStyle="TextStyle.Caption">
                    @alert.Source · @Display.FormatTimestamp(alert.Timestamp)
                </RadzenText>
            </RadzenStack>
        </RadzenCard>
    }
}

@code {
    private IReadOnlyList<AlertDto> _alerts = [];

    protected override void OnInitialized()
    {
        DashboardState.Changed += OnStateChanged;
        Refresh();
    }

    private void OnStateChanged() => InvokeAsync(() =>
    {
        Refresh();
        StateHasChanged();
    });

    private void Refresh() => _alerts = DashboardState.Alerts;

    public void Dispose() => DashboardState.Changed -= OnStateChanged;
}
