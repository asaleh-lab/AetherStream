@page "/weather"
@rendermode InteractiveServer
@using AetherStream.Dashboard.Models
@using AetherStream.Dashboard.Services
@inject DashboardState DashboardState
@inject DashboardDisplay Display
@implements IDisposable

<PageTitle>Weather - AetherStream</PageTitle>

<RadzenText TextStyle="TextStyle.H4" TagName="TagName.H2">Weather conditions</RadzenText>
<ConnectionStatus />

<RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" class="rz-mb-4">
    Weather readings are ingested by the datasource poll feed and flow through the stream join.
    Regional energy cards on the dashboard reflect the combined weather + turbine + grid state.
</RadzenAlert>

<RadzenRow Gap="1rem">
    @foreach (var region in _regions)
    {
        <RadzenColumn Size="12" SizeMD="6" SizeLG="4">
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.Overline">@region.Region</RadzenText>
                <RadzenText TextStyle="TextStyle.H6">Wind contribution</RadzenText>
                <RadzenText TextStyle="TextStyle.H3">@region.TotalWindPower.ToString("N0") kW</RadzenText>
                <RadzenText TextStyle="TextStyle.Caption">
                    Efficiency @DashboardDisplay.FormatEfficiencyPercent(region.EfficiencyScore) · updated @Display.FormatTimestamp(region.Timestamp)
                </RadzenText>
            </RadzenCard>
        </RadzenColumn>
    }
</RadzenRow>

@if (_regions.Count == 0)
{
    <RadzenText TextStyle="TextStyle.Body2">
        No regional energy snapshots yet.
    </RadzenText>
}

@code {
    private IReadOnlyList<EnergyStateDto> _regions = [];

    protected override void OnInitialized()
    {
        DashboardState.Changed += OnStateChanged;
        Refresh();
    }

    private void OnStateChanged() => InvokeAsync(() =>
    {
        Refresh();
        StateHasChanged();
    });

    private void Refresh() =>
        _regions = DashboardState.EnergyStates.OrderBy(r => r.Region).ToList();

    public void Dispose() => DashboardState.Changed -= OnStateChanged;
}
