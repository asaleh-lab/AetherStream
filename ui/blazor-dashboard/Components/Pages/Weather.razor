@page "/weather"

<PageTitle>Weather - AetherStream</PageTitle>

<RadzenText TextStyle="TextStyle.H4" TagName="TagName.H2">Weather conditions</RadzenText>
<RadzenText TextStyle="TextStyle.Body2" class="rz-mb-4 rz-color-secondary">
    Wind speed trends and environmental readings from the weather ingestion service.
</RadzenText>

<RadzenRow Gap="1rem">
    <RadzenColumn Size="12" SizeMD="6">
        <RadzenCard>
            <RadzenText TextStyle="TextStyle.Overline">Wind speed</RadzenText>
            <RadzenText TextStyle="TextStyle.H3">— m/s</RadzenText>
        </RadzenCard>
    </RadzenColumn>
    <RadzenColumn Size="12" SizeMD="6">
        <RadzenCard>
            <RadzenText TextStyle="TextStyle.Overline">Temperature</RadzenText>
            <RadzenText TextStyle="TextStyle.H3">— °C</RadzenText>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
