# Normalize line endings; LF in the repo by default
* text=auto eol=lf

# Windows-native script/project files keep CRLF
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.cmd   text eol=crlf
*.bat   text eol=crlf
*.sln   text eol=crlf
*.csproj text eol=crlf

# Always LF for shell scripts and the Maven wrapper
*.sh    text eol=lf
mvnw    text eol=lf

# Binary assets
*.jar   binary
*.png   binary
*.jpg   binary
*.ico   binary
